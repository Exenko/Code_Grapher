<?xml version="1.0" encoding="UTF-8"?>
<!--
    broker_config.xml — Broker routing table configuration.

    Consumed by: broker/router.cc::load_routing_table()
    Role: control (shapes routing behavior; content does not flow into forwarded messages)
    CodeGrapher edge: configures broker/router.cc::lookup_route (role:control)
-->
<BrokerConfig>
    <RoutingTable>
        <!-- Route: default consumer endpoint -->
        <Route>
            <Key>
                <Destination>consumer-default</Destination>
                <Priority>0</Priority>
                <Flags>0x00</Flags>
            </Key>
            <TargetAddress>tcp://localhost:9001</TargetAddress>
            <Weight>100</Weight>
        </Route>

        <!-- Route: high-priority consumer endpoint -->
        <Route>
            <Key>
                <Destination>consumer-priority</Destination>
                <Priority>10</Priority>
                <Flags>0x01</Flags>
            </Key>
            <TargetAddress>tcp://localhost:9002</TargetAddress>
            <Weight>50</Weight>
        </Route>

        <!-- Route: legacy WSDL consumer endpoint (separate from proto consumer) -->
        <Route>
            <Key>
                <Destination>consumer-legacy</Destination>
                <Priority>0</Priority>
                <Flags>0x02</Flags>
            </Key>
            <TargetAddress>tcp://localhost:9003</TargetAddress>
            <Weight>100</Weight>
        </Route>

        <!-- Route: dead letter queue (for ERROR_RECOVERY drop case) -->
        <Route>
            <Key>
                <Destination>dead-letter</Destination>
                <Priority>-1</Priority>
                <Flags>0xFF</Flags>
            </Key>
            <TargetAddress>tcp://localhost:9099</TargetAddress>
            <Weight>1</Weight>
        </Route>
    </RoutingTable>

    <RetryPolicy>
        <MaxRetries>3</MaxRetries>
        <RetryDelayMs>500</RetryDelayMs>
        <BackoffMultiplier>2</BackoffMultiplier>
    </RetryPolicy>

    <ErrorRecovery>
        <OnMaxRetries>drop</OnMaxRetries>  <!-- drop | escalate | dead-letter -->
        <NotifyPeers>true</NotifyPeers>    <!-- fires dispatch_event("ERROR") to all peers -->
    </ErrorRecovery>
</BrokerConfig>
