<?xml version="1.0" encoding="UTF-8"?>
<!--
    producer_config.xml — Producer serialization and retry configuration.

    Consumed by: producer/state_machine.cc::producer_fsm_init()
                 producer/encoder.cc::select_serializer()
    Role: control (shapes encoding path and retry behavior)
    CodeGrapher edge: configures producer/encoder.cc::select_serializer (role:control)
    CodeGrapher edge: configures producer/state_machine.cc::producer_fsm_init (role:control)
-->
<ProducerConfig>
    <Serialization>
        <!-- use_proto: 1 = proto path (encoder.cc), 0 = legacy WSDL path (legacy_encoder.cc) -->
        <!-- This flag drives the ENCODING state branch in the Producer FSM -->
        <UseProt>1</UseProt>
        <ProtoVersion>3</ProtoVersion>
        <LegacyWSDLEndpoint>http://localhost:8080/legacy/producer</LegacyWSDLEndpoint>
        <ProtoEndpoint>tcp://localhost:8080/proto</ProtoEndpoint>
    </Serialization>

    <Transport>
        <BrokerAddress>tcp://localhost:8090</BrokerAddress>
        <ConnectTimeoutMs>3000</ConnectTimeoutMs>
        <SendTimeoutMs>2000</SendTimeoutMs>
    </Transport>

    <AckPolicy>
        <!-- ACK = WRITE_COMPLETE event fired by Consumer:WRITING -->
        <AckTimeoutMs>5000</AckTimeoutMs>
        <MaxRetries>3</MaxRetries>
        <!-- OnTimeout: what Producer:WAITING_ACK does when timeout fires -->
        <OnTimeout>error</OnTimeout>  <!-- error | retry | drop -->
    </AckPolicy>

    <ErrorPolicy>
        <MaxConsecutiveErrors>3</MaxConsecutiveErrors>
        <!-- OnMaxErrors: escalate triggers FATAL state in Producer FSM -->
        <OnMaxErrors>escalate</OnMaxErrors>  <!-- escalate | reset | exit -->
        <NotifyPeers>true</NotifyPeers>      <!-- fires dispatch_event("ERROR") -->
    </ErrorPolicy>
</ProducerConfig>
